# ══════════════════════════════════════════════════════════
# Marketplace Application Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values

# ── Application Settings ──────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development    # or 'production'

# ── JWT Settings ──────────────────────────────────────────
JWT_SECRET_KEY=your_super_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440    # 24 hours

# ── MySQL Database ────────────────────────────────────────
DB_DRIVER=mysql        # Use 'mysql' or 'oracle'
DB_USER=appuser
DB_PASSWORD=password123
DB_HOST=localhost
DB_PORT=3306
DB_NAME=marketplace_db

# ── Oracle (optional) ─────────────────────────────────────
# DB_DRIVER=oracle
# ORACLE_USER=your_oracle_user
# ORACLE_PASSWORD=your_oracle_password
# ORACLE_DSN=your_oracle_dsn
# ORACLE_POOL_MIN=2
# ORACLE_POOL_MAX=5

# ══════════════════════════════════════════════════════════
# IMPORTANT:
#
# 1. Create the MySQL user before running:
#    mysql -u root -p
#    > CREATE USER 'appuser'@'localhost' IDENTIFIED BY 'password123';
#    > GRANT ALL PRIVILEGES ON marketplace_db.* TO 'appuser'@'localhost';
#    > FLUSH PRIVILEGES;
#
# 2. Change JWT_SECRET_KEY to a random value in production
#
# 3. Never commit this file with real secrets to git
#
# ══════════════════════════════════════════════════════════
