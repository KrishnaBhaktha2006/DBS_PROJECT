# ─────────────────────────────────────────────
#  Environment Configuration – Marketplace API
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development          # development | production

# ── JWT ──────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_long_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440      # 24 hours

# ── Database Driver ──────────────────────────
# Options: mysql | oracle
DB_DRIVER=mysql

# ── MySQL (used when DB_DRIVER=mysql) ────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=marketplace_db
MYSQL_POOL_SIZE=5

# ── Oracle (used when DB_DRIVER=oracle) ──────
# ORACLE_USER=system
# ORACLE_PASSWORD=your_oracle_password
# ORACLE_DSN=localhost:1521/XEPDB1
# ORACLE_POOL_MIN=2
# ORACLE_POOL_MAX=5
